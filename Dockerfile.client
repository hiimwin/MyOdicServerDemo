# Stage 1: Build
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy client project
COPY MyOidcServer/OidcWebClient/*.csproj ./ 
RUN dotnet restore

# Copy all client code
COPY MyOidcServer/OidcWebClient/ ./
RUN dotnet publish -c Release -o /app/publish

# Stage 2: Runtime
FROM nginx:alpine
COPY --from=build /app/publish /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]